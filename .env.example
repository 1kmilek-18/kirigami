# Kirigami 画像→PPTX — 機密情報は .env および環境変数のみで指定
# このファイルをコピーして .env を作成し、値を設定してください。
# .env はリポジトリにコミットしないでください。
#
# 別プロジェクトの .env を参照する場合:
# 自プロジェクト .env のあと、 presentation-maker/.env を自動で読込みます。
# その .env の GEMINI_API_KEY → GOOGLE_API_KEY、CLAUDE_API_KEY → ANTHROPIC_API_KEY として利用されます。

# レイヤー分解 (fal.ai)。未設定の場合は config.yaml の decompose.backend を cpu にするか、
# Web UI で「レイヤー分解」を「CPU (ローカル)」にすると fal.ai なしで動作します。
# キー取得: https://fal.ai/dashboard/keys
FAL_KEY=

# LLM 補正（presentation-maker の CLAUDE_API_KEY / GEMINI_API_KEY も参照可）
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Ollama はローカルでキー不要（http://localhost:11434 で利用）

# デバッグ: 処理が進まないとき KIRIGAMI_DEBUG=1 で起動すると temp/kirigami_debug.log に各ステップの時刻が記録されます
# KIRIGAMI_DEBUG=1
